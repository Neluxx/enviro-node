# Copy this file to `.env` in the project root — it is loaded automatically
# at startup. `.env` is gitignored so secrets stay local.

# --- Required ---

# Base URL of your REST API (must be HTTPS in production).
API_BASE_URL=https://api.example.com

# API authentication token, sent in the Authorization: Bearer header.
API_BEARER_TOKEN=your_secret_token_here

# Unique identifier for this node, sent with each reading.
NODE_UUID=your_unique_identifier_here

# --- Optional (defaults shown) ---

# UART port for the MH-Z19 CO2 sensor.
#MHZ19_PORT=/dev/ttyAMA0

# HTTP request timeout, in seconds.
#API_TIMEOUT=15

# Max readings shipped per run.
#API_BATCH_SIZE=50

# Bail out of the ship loop after this many consecutive failures.
#API_MAX_FAILURES=3

# Rotate the log file when it exceeds this size (bytes).
#LOG_MAX_BYTES=1000000

# Number of rotated log files to keep.
#LOG_BACKUP_COUNT=5
